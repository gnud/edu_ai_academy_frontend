# Copy this file to .env.development.local or .env.local and fill in your values.
# Never commit .env.*.local files.

# Base URL of the Django API server.
# In development this is proxied by Vite — the value here is used as the proxy target.
# In production builds the value is inlined at build time as the fetch base URL.
VITE_API_URL=http://localhost:8000